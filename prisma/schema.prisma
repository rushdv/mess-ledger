generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("MEMBER") // ADMIN | MEMBER
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  member    Member?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Mess Core ───────────────────────────────────────────────────────────────

model Member {
  id        String   @id @default(cuid())
  userId    String   @unique
  phone     String?
  joinedAt  DateTime @default(now())
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealCounts      MealCount[]
  payments        Payment[]
  individualCosts IndividualCost[]
  sharedCosts     SharedCostMember[]
}

// One record per member per day
model MealCount {
  id        String   @id @default(cuid())
  memberId  String
  date      DateTime
  breakfast Int      @default(0)
  lunch     Int      @default(0)
  dinner    Int      @default(0)
  total     Int      @default(0) // computed: breakfast+lunch+dinner
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, date])
}

// Monthly bazar (grocery) cost entries
model BazarCost {
  id          String   @id @default(cuid())
  month       Int      // 1-12
  year        Int
  amount      Float
  description String?
  date        DateTime @default(now())
  addedBy     String   // userId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Monthly utility costs (electricity, gas, water, etc.)
model UtilityCost {
  id          String   @id @default(cuid())
  month       Int
  year        Int
  type        String   // ELECTRICITY | GAS | WATER | INTERNET | OTHER
  amount      Float
  description String?
  addedBy     String   // userId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Shared costs split among selected members only
model SharedCost {
  id          String   @id @default(cuid())
  month       Int
  year        Int
  amount      Float
  description String?
  addedBy     String   // userId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members SharedCostMember[]
}

// Junction table: which members share this cost
model SharedCostMember {
  id           String @id @default(cuid())
  sharedCostId String
  memberId     String

  sharedCost SharedCost @relation(fields: [sharedCostId], references: [id], onDelete: Cascade)
  member     Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([sharedCostId, memberId])
}

// Individual costs per member (personal expenses charged to a specific member)
model IndividualCost {
  id          String   @id @default(cuid())
  memberId    String
  month       Int
  year        Int
  amount      Float
  description String?
  addedBy     String   // userId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

// Member payments (deposits)
model Payment {
  id        String   @id @default(cuid())
  memberId  String
  month     Int
  year      Int
  amount    Float
  note      String?
  addedBy   String   // userId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

// Cached monthly calculation result (recalculated on demand)
model MonthlyReport {
  id              String   @id @default(cuid())
  month           Int
  year            Int
  totalMeals      Int
  totalBazarCost  Float
  totalUtility    Float
  totalCost       Float
  mealRate        Float    // totalBazarCost / totalMeals
  utilityPerHead  Float    // totalUtility / activeMembers
  calculatedAt    DateTime @default(now())

  memberSummaries MemberMonthlySummary[]

  @@unique([month, year])
}

model MemberMonthlySummary {
  id             String @id @default(cuid())
  reportId       String
  memberId       String
  memberName     String
  totalMeals     Int
  mealCost       Float  // meals × mealRate
  utilityShare   Float
  individualCost Float  @default(0) // personal/individual charges
  sharedCost     Float  @default(0) // shared costs split among selected members
  totalCost      Float  // mealCost + utilityShare + individualCost + sharedCost
  totalPaid      Float
  due            Float  // totalCost - totalPaid (positive = owes, negative = advance)

  report MonthlyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}
