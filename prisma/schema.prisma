generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth (Better Auth) ──────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  password      String?
  role          String    @default("MEMBER")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  messMembers   MessMember[]
  member        Member[]
  adminLogs     AdminAuditLog[]
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
}

// ─── Mess Core ───────────────────────────────────────────────────────────────

// Mess (Tenant/Group) - Each mess is an independent group
model Mess {
  id          String   @id @default(cuid())
  name        String   // e.g., "Dhaka Mess", "Student Hostel A"
  code        String   @unique // Unique invite code (e.g., "DHAKA2024")
  description String?
  createdBy   String   // userId of creator
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messMembers     MessMember[]
  members         Member[]
  mealCounts      MealCount[]
  bazarCosts      BazarCost[]
  utilityCosts    UtilityCost[]
  sharedCosts     SharedCost[]
  individualCosts IndividualCost[]
  payments        Payment[]
  monthlyReports  MonthlyReport[]
  paymentRequests PaymentRequest[]
  expenseRequests ExpenseRequest[]
  notices         Notice[]
}

// Junction table: User's membership in different messes
model MessMember {
  id        String   @id @default(cuid())
  userId    String
  messId    String
  role      String   @default("MEMBER") // ADMIN | MODERATOR | MEMBER
  joinedAt  DateTime @default(now())
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  mess Mess @relation(fields: [messId], references: [id], onDelete: Cascade)

  @@unique([userId, messId])
}

model Member {
  id        String   @id @default(cuid())
  userId    String
  messId    String
  phone            String?
  defaultBreakfast Int      @default(0)
  defaultLunch     Int      @default(0)
  defaultDinner    Int      @default(0)
  joinedAt         DateTime @default(now())
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  mess            Mess               @relation(fields: [messId], references: [id], onDelete: Cascade)
  mealCounts      MealCount[]
  payments        Payment[]
  individualCosts IndividualCost[]
  sharedCosts     SharedCostMember[]
  paymentRequests PaymentRequest[]
  expenseRequests ExpenseRequest[]
  bazarCosts      BazarCost[]

  @@unique([userId, messId])
}

// One record per member per day
model MealCount {
  id        String   @id @default(cuid())
  memberId  String
  messId    String
  date      DateTime
  breakfast Int      @default(0)
  lunch     Int      @default(0)
  dinner    Int      @default(0)
  total     Int      @default(0) // computed: breakfast+lunch+dinner
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  mess   Mess   @relation(fields: [messId], references: [id], onDelete: Cascade)

  @@unique([memberId, date])
}

// Monthly bazar (grocery) cost entries
model BazarCost {
  id          String   @id @default(cuid())
  messId      String
  memberId    String?  // optional — which member did the bazar
  month       Int      // 1-12
  year        Int
  amount      Decimal
  description String?
  date        DateTime @default(now())
  addedBy     String   // userId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mess   Mess    @relation(fields: [messId], references: [id], onDelete: Cascade)
  member Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)
}

// Monthly utility costs (electricity, gas, water, etc.)
model UtilityCost {
  id          String   @id @default(cuid())
  messId      String
  month       Int
  year        Int
  type        String   // ELECTRICITY | GAS | WATER | INTERNET | OTHER
  amount      Decimal
  description String?
  date        DateTime @default(now()) // Date of the utility bill
  addedBy     String   // userId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mess Mess @relation(fields: [messId], references: [id], onDelete: Cascade)
}

// Shared costs split among selected members only
model SharedCost {
  id          String   @id @default(cuid())
  messId      String
  month       Int
  year        Int
  amount      Decimal
  description String?
  date        DateTime @default(now()) // Date of the shared cost
  addedBy     String   // userId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mess    Mess               @relation(fields: [messId], references: [id], onDelete: Cascade)
  members SharedCostMember[]
}

// Junction table: which members share this cost
model SharedCostMember {
  id           String @id @default(cuid())
  sharedCostId String
  memberId     String

  sharedCost SharedCost @relation(fields: [sharedCostId], references: [id], onDelete: Cascade)
  member     Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([sharedCostId, memberId])
}

// Individual costs per member (personal expenses charged to a specific member)
model IndividualCost {
  id          String   @id @default(cuid())
  memberId    String
  messId      String
  month       Int
  year        Int
  amount      Decimal
  description String?
  date        DateTime @default(now()) // Date of the individual cost
  addedBy     String   // userId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  mess   Mess   @relation(fields: [messId], references: [id], onDelete: Cascade)
}

// Member payments (deposits)
model Payment {
  id        String   @id @default(cuid())
  memberId  String
  messId    String
  month     Int
  year      Int
  amount    Decimal
  note      String?
  date      DateTime @default(now()) // Date of payment
  addedBy   String   // userId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  mess   Mess   @relation(fields: [messId], references: [id], onDelete: Cascade)
}

// Cached monthly calculation result (recalculated on demand)
model MonthlyReport {
  id              String   @id @default(cuid())
  messId          String
  month           Int
  year            Int
  totalMeals      Int
  totalBazarCost  Decimal
  totalUtility    Decimal
  totalCost       Decimal
  mealRate        Decimal    // totalBazarCost / totalMeals
  utilityPerHead  Decimal    // totalUtility / activeMembers
  calculatedAt    DateTime   @default(now())

  mess            Mess                   @relation(fields: [messId], references: [id], onDelete: Cascade)
  memberSummaries MemberMonthlySummary[]

  @@unique([messId, month, year])
}

model MemberMonthlySummary {
  id             String  @id @default(cuid())
  reportId       String
  memberId       String
  memberName     String
  totalMeals     Int
  mealCost       Decimal  // meals × mealRate
  utilityShare   Decimal
  individualCost Decimal  @default(0)  // personal/individual charges
  sharedCost     Decimal  @default(0)  // shared costs split among selected members
  totalCost      Decimal  // mealCost + utilityShare + individualCost + sharedCost
  totalPaid      Decimal
  due            Decimal  // totalCost - totalPaid (positive = owes, negative = advance)

  report MonthlyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

// ─── Requests & Notifications ──────────────────────────────────────────────────

model PaymentRequest {
  id        String   @id @default(cuid())
  messId    String
  memberId  String
  amount    Decimal
  trxId     String?
  note      String?
  status    String   @default("PENDING") // PENDING | APPROVED | REJECTED
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mess   Mess   @relation(fields: [messId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model ExpenseRequest {
  id          String   @id @default(cuid())
  messId      String
  memberId    String
  amount      Decimal
  description String
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mess   Mess   @relation(fields: [messId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model Notice {
  id        String   @id @default(cuid())
  messId    String
  content   String
  authorId  String   // User ID
  createdAt DateTime @default(now())
  expiresAt DateTime?

  mess Mess @relation(fields: [messId], references: [id], onDelete: Cascade)
}

// ─── Super Admin ─────────────────────────────────────────────────────────────

model AdminAuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  details   String?
  createdAt DateTime @default(now())

  admin     User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
}
